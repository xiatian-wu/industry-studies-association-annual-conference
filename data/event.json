{
  "name": "Industry Studies Association Annual Conference",
  "description": "Washington D.C. | June 3-5, 2026",
  "websiteUrl": "https://www.industrystudies.org/events/2026-washington-dc-conference-v2",
  "logoUrl": "data:image/png;base64,",
  "similarity_config": {
    "threshold": 0.3,
    "components": [
      {
        "field": "interests",
        "type": "jaccard",
        "weight": 1,
        "enabled": true,
        "label": "Shared interests",
        "hint": "Two people show up as connected when their interest lists overlap."
      },
      {
        "field": "affiliation",
        "type": "exact_match",
        "weight": 0.6,
        "enabled": true,
        "label": "Same affiliation",
        "hint": "Two people show up as connected when they list the same institution."
      },
      {
        "field": "country",
        "type": "exact_match",
        "weight": 0.3,
        "enabled": false,
        "label": "Same country",
        "hint": "Off by default. Turn this on for events where geography matters."
      },
      {
        "field": "bio",
        "type": "text_keywords",
        "weight": 0.6,
        "enabled": true,
        "label": "Similar bios",
        "hint": "Two people show up as connected when their bios mention similar topics."
      }
    ]
  }
}